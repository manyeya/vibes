{
  "name": "harness-vibes",
  "version": "1.0.0",
  "description": "DeepAgents framework - A powerful AI agent orchestrator with multi-step reasoning, memory, and collaboration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./backend": {
      "import": "./dist/src/backend/sqlitebackend.js",
      "types": "./dist/src/backend/sqlitebackend.d.ts"
    },
    "./persistence": {
      "import": "./dist/src/persistence/index.js",
      "types": "./dist/src/persistence/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build index.ts src/backend/sqlitebackend.ts src/persistence/index.ts --outdir dist --target bun --sourcemap=external && tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun run --watch index.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@ai-sdk/langchain": "^2.0.42",
    "@ai-sdk/openai": "^3.0.12",
    "@exalabs/ai-sdk": "^1.0.5",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/core": "^1.1.15",
    "ai": "^6.0.39",
    "deepagents": "^1.4.1",
    "langchain": "^1.2.10",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@ai-sdk/openai": "^3.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "multi-agent",
    "orchestrator",
    "bun",
    "langchain",
    "ai-sdk"
  ],
  "author": "",
  "license": "MIT"
}
